# Database
# Use a full connection string for your DB. Example for Neon/Postgres:
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<HOST>/<DB_NAME>?sslmode=verify-full&channel_binding=require

# Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=http://localhost:3000/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=http://localhost:3000/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=http://localhost:3000/sign-up
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_CLERK_FRONTEND_API=your-clerk-frontend-api

# Hume
NEXT_PUBLIC_HUME_CONFIG_ID=your-hume-config-id
HUME_API_KEY=your-hume-api-key
HUME_SECRET_KEY=your-hume-secret-key

# AI / Gemini
GEMINI_API_KEY=your_gemini_api_key

# ArcJet
ARCJET_KEY=your_arcjet_key
